# HomeCast Environment Variables
# Copy this file to .env and adjust as needed

# Server port for the web interface (default: 3000)
PORT=3000

# Set to 'production' for deployment
NODE_ENV=production

# Hours before inactive devices are removed from the list (default: 3)
STALE_DEVICE_TIMEOUT_HOURS=3

# Optional: Manually set your server's LAN IP if auto-detection fails
# HOST_IP=192.168.1.100

# Optional: Persistent CSRF secret (auto-generated on each restart if not set)
# CSRF_SECRET=your-random-secret-here

# Optional: Disable CSRF protection (not recommended)
# DISABLE_CSRF=true

# ⚠️ DANGER: Disable SSRF protection (not recommended for public deployments)
# DISABLE_SSRF_PROTECTION=true

# --- Performance Tuning (advanced) ---

# Maximum stream recovery attempts before giving up (default: 3)
# MAX_RECOVERY_ATTEMPTS=3

# Seconds of buffering before a stream is considered stalled (default: 15)
# STALL_TIMEOUT_SECONDS=15

# Heartbeat check interval in seconds (default: 5)
# HEARTBEAT_INTERVAL_SECONDS=5

# Missed heartbeats before marking connection unhealthy (default: 3)
# MAX_MISSED_HEARTBEATS=3

# Reconnection delay in seconds (default: 10)
# RECONNECT_DELAY_SECONDS=10

# Maximum reconnection attempts (default: 3)
# MAX_RECONNECT_ATTEMPTS=3

# VOD playlist cache TTL in seconds (default: 60)
# CACHE_TTL_VOD_SECONDS=60

# Live stream playlist cache TTL in seconds (default: 4)
# CACHE_TTL_LIVE_SECONDS=4
